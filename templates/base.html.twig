<!DOCTYPE html>
<html lang="fr">
    <head>
        <!-- Meta Tags pour le SEO -->
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <meta name="description" content="Mots de passe forts et uniques pour sécuriser vos comptes en ligne. Générez-les facilement avec Passphrase, un outil open source fiable.">
        <meta name="keywords" content="passphrase, générateur de mot de passe, sécurité, entropie, mot de passe sécurisé, open source">
        <meta name="robots" content="index, follow">
        <meta name="author" content="Alexandre Monchain">        
        <!-- Open Graph meta tags (pour les réseaux sociaux) -->
        <meta property="og:title" content="Passphrase - Générateur de phrases de passe sécurisées">
        <meta property="og:description" content="Générez facilement des phrases de passe sécurisées. Un outil open source pour améliorer la sécurité de vos comptes.">
        <meta property="og:image" content="{{ asset('images/passphrase-thumbnail.png') }}">
        <meta property="og:url" content="{{ app.request.uri }}">
        <meta property="og:type" content="website">
        <meta property="og:site_name" content="Passphrase">
        <!-- Twitter Card meta tags (pour les partages sur Twitter) -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="Passphrase - Générateur de phrases de passe sécurisées">
        <meta name="twitter:description" content="Améliorez la sécurité de vos comptes avec des phrases de passe uniques. Un outil open source.">
        <meta name="twitter:image" content="{{ asset('images/passphrase-thumbnail.png') }}">
        <!-- Favicon -->
        <link rel="icon" href="{{ asset('assets/favicon.svg') }}" type="image/svg+xml">
        <!-- Google tag (gtag.js) -->
            <script async src="https://www.googletagmanager.com/gtag/js?id=G-NYVGX0VQJ8"></script>
            <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-NYVGX0VQJ8');
            </script>
        <!-- END Google tag (gtag.js) -->
        <link rel="canonical" href="{{ app.request.scheme ~ '://' ~ app.request.host ~ app.request.pathInfo }}">
        <!-- Theme: set immediately to avoid flash of wrong theme -->
        <script>(function(){var t=localStorage.getItem('theme');if(t==='dark')document.documentElement.setAttribute('data-theme','dark');}());</script>
        <!-- Google Fonts: Inter -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <title>{% block title %}Passphrase{% endblock %}</title>        
        <link defer rel="stylesheet" href="{{ asset('assets/bootstrap.min.css') }}">
        <link defer rel="stylesheet" href="{{ asset('assets/app.css') }}">
    </head>
    <body>
        <!-- Navbar moderne -->
        <nav class="navbar-modern">
            <div class="nav-container">
                <a class="nav-logo" href="{{ path('app_home') }}">
                    <img src="{{ asset('assets/favicon.svg') }}" width="26" height="26" alt="" aria-hidden="true"> Passphrase
                </a>
                <button class="nav-toggle" aria-label="Toggle navigation" onclick="toggleNav()">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <div class="nav-menu" id="navMenu">
                    <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                    <a class="nav-link" href="{{ path('blog_show', { 'slug': 'entropie' }) }}">Blog</a>
                    <a class="nav-link" href="{{ path('api_documentation') }}">API</a>
                    <a class="nav-link nav-extension" href="https://chromewebstore.google.com/detail/générateur-de-passphrase/bhlgfoknmmhgpfoanhoemjccephcanjd" target="_blank" rel="noopener" title="Extension Chrome">
                        <i class="fab fa-chrome"></i>
                    </a>
                    <button id="theme-toggle" class="nav-theme-toggle" aria-label="Changer de thème" title="Thème clair / sombre">
                        <i class="fas fa-moon"></i>
                    </button>
                </div>
            </div>
        </nav>

        <!-- Contenu principal -->
        <main class="main-content">
        {% block body %}{% endblock %}
        </main>

        <!-- Footer moderne -->
        <footer class="footer-modern">
            <div class="footer-container">
                <div class="footer-content">
                    <p class="footer-text">
                        <strong>Passphrase v{{ app_version }}</strong> • © 2024-2026 Alexandre MONCHAIN
                    </p>
                    <p class="footer-links">
                        <a href="https://github.com/AlexandreMonchain/Passphrase" target="_blank" rel="noopener" aria-label="GitHub">
                            <i class="fab fa-github"></i>
                        </a>
                        <span class="separator">•</span>
                        <a href="https://github.com/AlexandreMonchain/Passphrase/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
                    </p>
                </div>
            </div>
        </footer>

        <script defer src="{{ asset('assets/app.js') }}"></script>
        <script defer src="{{ asset('assets/bootstrap.min.js') }}"></script>
        <script>
            function toggleNav() {
                const menu = document.getElementById('navMenu');
                menu.classList.toggle('active');
            }
            document.addEventListener('click', function(e) {
                const nav = document.querySelector('.navbar-modern');
                if (!nav.contains(e.target)) {
                    document.getElementById('navMenu').classList.remove('active');
                }
            });
        </script>
        {% block script %}{% endblock %}
    </body>
</html>

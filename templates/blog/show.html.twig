{% extends 'base.html.twig' %}

{% block title %}Blog - {{ slug }}{% endblock %}

{% block body %}
    <section class="hero-section">
        <div class="hero-icon">📚</div>
        <h1 class="hero-title">Blog Passphrase</h1>
        <p class="hero-subtitle">Articles et guides sur la sécurité des mots de passe</p>
    </section>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <article class="card-modern blog-content">
                    {{ content|sanitize_html|raw }}
                </article>

                <div class="mt-5 text-center">
                    <a href="{{ path('app_home') }}" class="btn btn-primary">
                        <i class="fas fa-arrow-left"></i> Retour au générateur
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Blog — Sécurité des mots de passe · Passphrase{% endblock %}

{% block body %}
    <section class="hero-section">
        <div class="hero-icon">📖</div>
        <h1 class="hero-title">Blog</h1>
        <p class="hero-subtitle">Sécurité, cryptographie et bonnes pratiques</p>
    </section>

    <div class="container-lg pb-5">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">

                <article class="card-modern blog-content">
                    {{ content|sanitize_html|raw }}
                </article>

                <div class="mt-4 text-center">
                    <a href="{{ path('app_home') }}" class="btn btn-outline-primary">
                        <i class="fas fa-arrow-left"></i> Retour au générateur
                    </a>
                </div>

            </div>
        </div>
    </div>
{% endblock %}

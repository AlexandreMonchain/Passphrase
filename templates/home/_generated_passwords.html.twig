{% if generated_passwords is not empty %}
    <div class="password-board card-modern mb-3">
        <div class="password-grid-2cols">
            {% for item in generated_passwords %}
                <div class="password-card-compact">
                    <div class="password-main-compact">
                        <p class="password-value-compact">{{ item.password }}</p>
                        <span class="badge {{ item.class }} entropy-badge-compact">Entropie: {{ item.entropy }} bits</span>
                    </div>
                    <button aria-label="Copier le mot de passe" class="btn copy-btn-round" data-password="{{ item.password }}">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
{% if generated_passwords is not empty %}
    <div class="password-board card-modern mb-3">
        <div class="password-grid-2cols">
            {% for item in generated_passwords %}
                <div class="password-card-compact" style="cursor:pointer" data-password="{{ item.password }}">
                    <div class="password-main-compact">
                        <p class="password-value-compact">{{ item.password }}</p>
                        <span class="badge {{ item.class }} entropy-badge-compact">{{ item.entropy }} bits · {{ item.length }} car.</span>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}

{% extends 'base.html.twig' %}

{% block title %}Générateur de mots de passe{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-icon">🔐</div>
        <h1 class="hero-title">Générateur de Passphrase</h1>
        <p class="hero-subtitle">Créez des mots de passe forts et uniques. Sécurisez vos comptes en ligne.</p>
    </section>

    <div class="container">
        <div class="row g-4">
            <!-- Colonne Gauche: Formulaire & Génération -->
            <div class="col-lg-8">
                
                <!-- Messages d'erreur/succès -->
                <div id="form-messages" role="alert" aria-live="polite" aria-atomic="true"></div>

                <!-- Mots de passe générés -->
                <div id="generated-passwords" class="mb-3">
                    {% include 'home/_generated_passwords.html.twig' %}
                </div>

                <!-- Bouton de génération + loading (hors du formulaire, lié par form="...") -->
                <div class="mb-4 text-center">
                    {{ form_widget(form.generate, {'attr': {'class': 'btn btn-primary btn-lg', 'form': 'password-generator-form', 'aria-label': 'Générer des mots de passe'}}) }}
                    <div id="loading-animation" class="d-none mt-3" role="status" aria-live="polite">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Génération en cours...</span>
                        </div>
                        <p class="mt-2 text-muted">Génération en cours...</p>
                    </div>
                </div>

                <!-- Formulaire de génération -->
                <div class="card-modern">
                    {{ form_start(form, {'attr': {'id': 'password-generator-form', 'novalidate': 'novalidate'}}) }}

                    <h2 class="card-title">
                        <i class="fas fa-sliders-h"></i> Personnalisation
                    </h2>

                    <!-- Grille de formulaire -->
                    <div class="row gy-3">
                        <!-- Ligne 1: Nombre de mots et Séparateur -->
                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.nb_mots, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.nb_mots, {'attr': {'class': 'form-control', 'aria-describedby': 'help-nb_mots'}}) }}
                                <small id="help-nb_mots" class="form-text">Nombre de mots: 2 à 7</small>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                {{ form_label(form.separateur, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.separateur, {'attr': {'class': 'form-control'}}) }}
                            </div>
                        </div>

                        <!-- Ligne 2: Longueur minimale -->
                        <div class="col-12">
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    {{ form_label(form.longueur_minimale, null, {'label_attr': {'class': 'form-label mb-0'}}) }}
                                    <span class="fw-semibold" id="longueur-display">{{ form.longueur_minimale.vars.value }}</span>
                                </div>
                                {{ form_widget(form.longueur_minimale, {'attr': {'class': 'form-range', 'min': '8', 'max': '50'}}) }}
                            </div>
                        </div>

                        <!-- Ligne 3: Longueur nombres, Caractères spéciaux et Nombre de résultats -->
                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.longueur_nombre, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.longueur_nombre, {'attr': {'class': 'form-control'}}) }}
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.caractere_special, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.caractere_special, {'attr': {'class': 'form-control'}}) }}
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="mb-3">
                                {{ form_label(form.nb_resultats, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.nb_resultats, {'attr': {'class': 'form-control'}}) }}
                            </div>
                        </div>

                        <!-- Ligne 4: Checkboxes -->
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-check">
                                        {{ form_widget(form.majuscule_debut, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.majuscule_debut, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check">
                                        {{ form_widget(form.majuscule_aleatoire, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.majuscule_aleatoire, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check">
                                        {{ form_widget(form.caracteres_accentues, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.caracteres_accentues, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Bouton Reset -->
                        <div class="col-12 text-center mt-2">
                            <button type="button" id="load-defaults-btn" class="btn btn-secondary btn-sm" aria-label="Réinitialiser les paramètres">
                                <i class="fas fa-redo-alt"></i> Réinitialiser
                            </button>
                        </div>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>

            <!-- Colonne Droite: Légende Entropie -->
            <div class="col-lg-4">
                <div class="entropy-legend card-modern">
                    <h3 class="card-title">
                        <i class="fas fa-info-circle"></i> Entropie
                    </h3>
                    <ul>
                        <li>
                            <span class="very-weak" aria-label="Très faible"></span>
                            <strong>Très faible</strong> &lt; 80 bits
                        </li>
                        <li>
                            <span class="weak" aria-label="Faible"></span>
                            <strong>Faible</strong> &lt; 100 bits
                        </li>
                        <li>
                            <span class="medium" aria-label="Acceptable"></span>
                            <strong>Acceptable</strong> &lt; 120 bits
                        </li>
                        <li>
                            <span class="good" aria-label="Bon"></span>
                            <strong>Bon</strong> &lt; 140 bits
                        </li>
                        <li>
                            <span class="very-strong" aria-label="Très fort"></span>
                            <strong>Très fort</strong> ≥ 140 bits
                        </li>
                    </ul>

                    <!-- Lien vers la page du Blog -->
                    <div class="text-center mt-3">
                        <a href="{{ path('blog_show', {'slug': 'entropie'}) }}" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-book"></i> En savoir plus
                        </a>
                    </div>
                </div>

                <!-- Card API Info -->
                <div class="card-modern mt-4 api-card">
                    <h3 class="card-title">
                        <i class="fas fa-code"></i> API
                    </h3>
                    <p class="text-muted api-description">Une API REST est disponible pour intégrer la génération de passphrases dans vos applications. Consultez la documentation complète pour connaître tous les paramètres et exemples.</p>
                    <a href="{{ path('api_documentation') }}" class="btn btn-secondary btn-sm">
                        <i class="fas fa-book"></i> Docs
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Extension Chrome Banner -->
    <div id="extension-popup" class="extension-banner-bottom" role="complementary" aria-label="Promotion extension Chrome">
        <div class="extension-content">
            🚀 Découvrez l'extension Chrome pour générer vos mots de passe plus rapidement !
        </div>
        <a href="https://chromewebstore.google.com/detail/générateur-de-passphrase/bhlgfoknmmhgpfoanhoemjccephcanjd" target="_blank" rel="noopener" class="btn btn-light btn-sm">
            Installer
        </a>
        <button id="popup-close" class="popup-close-btn" aria-label="Fermer la notification">✕</button>
    </div>

{% endblock %}